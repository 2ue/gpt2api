# ================================================================
# 服务器拉 GHCR 镜像直接部署模板
# 用法:
#   cp .env.example .env
#   修改下面各项
#   docker compose up -d
# ================================================================

# ---- Image ----
SERVER_IMAGE=docker.io/huby11111/gpt2api:0.0.4

# ---- Server ----
TZ=Asia/Shanghai
HTTP_PORT=8080
APP_ENV=prod
APP_BASE_URL=https://api.example.com
LOG_LEVEL=info
LOG_FORMAT=json
UPSTREAM_REQUEST_TIMEOUT_SEC=60
UPSTREAM_SSE_READ_TIMEOUT_SEC=300

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=please_change_me_root
MYSQL_USER=gpt2api
MYSQL_PASSWORD=please_change_me
MYSQL_DATABASE=gpt2api
MYSQL_MAX_OPEN_CONNS=100

# ---- Redis ----
REDIS_PASSWORD=
REDIS_POOL_SIZE=100

# ---- Security (生产强制改!) ----
JWT_SECRET=please_change_to_a_32_character_random_string_abcdef
CRYPTO_AES_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ---- Backup ----
BACKUP_RETENTION=30
BACKUP_ALLOW_RESTORE=false

# ---- Network ----
DNS_PRIMARY=8.8.8.8
DNS_FALLBACK=1.1.1.1

# ---- EPay (可选) ----
EPAY_GATEWAY_URL=
EPAY_PID=
EPAY_KEY=
EPAY_NOTIFY_URL=
EPAY_RETURN_URL=
EPAY_SIGN_TYPE=MD5
EPAY_EXPIRES_MIN=30

# ---- SMTP (可选) ----
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=GPT2API
SMTP_USE_TLS=true
